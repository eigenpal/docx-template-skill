{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "skills/docx-template/agent",
    "outDir": "skills/docx-template/agent/dist",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["skills/docx-template/agent/**/*.ts"],
  "exclude": ["skills/docx-template/agent/dist"]
}
